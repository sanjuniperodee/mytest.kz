{
  "name": "bilimland",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:api:force": "turbo run build --filter=@bilimland/api --force",
    "lint": "turbo lint",
    "db:migrate": "cd apps/api && npm run migrate:deploy:safe",
    "db:migrate:dev": "cd apps/api && npx prisma migrate dev",
    "db:seed": "cd apps/api && npx prisma db seed",
    "db:generate": "cd apps/api && npx prisma generate",
    "test:api": "npm run test:api -w @bilimland/api",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2.3.0"
  },
  "overrides": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "multer": "^2.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "webpack": "^5.106.0"
  },
  "packageManager": "npm@10.0.0"
}

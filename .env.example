# Database
DATABASE_URL=postgresql://bilimland:bilimland@localhost:5432/bilimland

# Redis
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_CHANNEL_URL=https://t.me/your_channel
TELEGRAM_CHANNEL_REQUIRED=true
# HTTPS URL of the Mini App (inline «Открыть» in chat); must match BotFather Web App URL
TELEGRAM_WEB_APP_URL=https://my-test.kz

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Google OAuth — один или несколько client ID через запятую (audience id_token).
# Обязательно включите веб-клиент; для входа из мобильного приложения добавьте iOS и Android client ID из консоли Google.
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com,your_ios_client_id.apps.googleusercontent.com,your_android_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# App
API_PORT=3000
NODE_ENV=development
PUBLIC_SITE_URL=https://my-test.kz
PUBLIC_API_BASE_URL=https://my-test.kz

# DB snapshots (daily backups)
# In production defaults to enabled unless explicitly set to false
DB_SNAPSHOT_ENABLED=true
# Local server time (24h)
DB_SNAPSHOT_HOUR=6
DB_SNAPSHOT_MINUTE=0
# Keep only recent N days
DB_SNAPSHOT_RETENTION_DAYS=7
# Optional absolute path (default: apps/api/backups/db-snapshots)
# DB_SNAPSHOT_DIR=/var/backups/bilimland/db

# Subscription engine v2 rollout
SUBSCRIPTION_ENGINE_V2=false
SUBSCRIPTION_ENGINE_V2_DUAL_READ=true
SUBSCRIPTION_ENGINE_V2_DUAL_WRITE=true
SIGNUP_PLAN_TEMPLATE_CODE=free_ent_trial
USER_TIMEZONE_COOLDOWN_DAYS=30

# Freedom Pay
# Kaspi Pay (kaspi-pos-automation) — сессия кассира после OTP; URL сервиса см. https://github.com/tapter-dev/kaspi-pos-automation
# KASPI_API_URL=http://localhost:3000
# KASPI_TOKEN_SN=
# KASPI_VTOKEN_SECRET=
# KASPI_PROFILE_ID=
# KASPI_ORGANIZATION_ID=
# Секрет для страницы настройки сессии и POST/GET /api/v1/billing/kaspi/setup/* (заголовок X-Kaspi-Session-Setup-Secret)
# KASPI_SESSION_SETUP_SECRET=
# Опционально: ключ Redis для сохранения сессии после OTP (по умолчанию bilimland:kaspi-pos:session)
# KASPI_SESSION_REDIS_KEY=
# Секрет для POST /api/v1/billing/kaspi/webhook (X-Webhook-Signature), тот же что в webhooks.json
# KASPI_WEBHOOK_SECRET=

FREEDOMPAY_MERCHANT_ID=your_merchant_id
FREEDOMPAY_SECRET_KEY=your_secret_key
# Optional payout secret (if you use payouts API separately)
FREEDOMPAY_PAYOUT_SECRET_KEY=your_payout_secret
# true -> https://test-api.freedompay.kz, false -> https://api.freedompay.kz
FREEDOMPAY_SANDBOX=true
# Optional override for gateway host
# FREEDOMPAY_API_URL=https://test-api.freedompay.kz
# Callback endpoint visible from internet
FREEDOMPAY_CALLBACK_URL=https://api.my-test.kz/api/v1/billing/freedompay/callback
# Script name used in signature verification for callback URL path
FREEDOMPAY_CALLBACK_SCRIPT=callback
# Optional custom redirects
# FREEDOMPAY_SUCCESS_URL=https://my-test.kz/paywall?payment=success
# FREEDOMPAY_FAILURE_URL=https://my-test.kz/paywall?payment=failed

# Apple In-App Purchase (required for iOS in-app subscriptions)
# APPLE_IAP_SHARED_SECRET=app_store_connect_shared_secret
# Optional JSON map product_id -> internal billing plan id
# APPLE_IAP_PRODUCT_PLAN_MAP={"com.sanjuniperodee.mobile.premium.trial":"trial","com.sanjuniperodee.mobile.premium.week":"week","com.sanjuniperodee.mobile.premium.month":"month","com.sanjuniperodee.mobile.premium.annual":"annual"}

# Bulk import API (POST /api/v1/bulk/*) — только для временного наполнения; выключите в проде
# BULK_IMPORT_ENABLED=true
# Опционально: если задан, все запросы к /bulk/* кроме GET /bulk/status требуют заголовок X-Bulk-Import-Token
# BULK_IMPORT_SECRET=long_random_string

# Lifecycle Telegram notifications
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_POLL_INTERVAL_MINUTES=15
NOTIFICATIONS_BATCH_SIZE=50
NOTIFICATIONS_QUIET_HOURS=22-09

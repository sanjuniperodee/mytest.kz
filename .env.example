# Database
DATABASE_URL=postgresql://bilimland:bilimland@localhost:5432/bilimland

# Redis
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel
# HTTPS URL of the Mini App (inline «Открыть» in chat); must match BotFather Web App URL
TELEGRAM_WEB_APP_URL=https://my-test.kz

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# App
API_PORT=3000
NODE_ENV=development
PUBLIC_SITE_URL=https://my-test.kz
PUBLIC_API_BASE_URL=https://my-test.kz

# Freedom Pay
FREEDOMPAY_MERCHANT_ID=your_merchant_id
FREEDOMPAY_SECRET_KEY=your_secret_key
# Optional payout secret (if you use payouts API separately)
FREEDOMPAY_PAYOUT_SECRET_KEY=your_payout_secret
# true -> https://test-api.freedompay.kz, false -> https://api.freedompay.kz
FREEDOMPAY_SANDBOX=true
# Optional override for gateway host
# FREEDOMPAY_API_URL=https://test-api.freedompay.kz
# Callback endpoint visible from internet
# FREEDOMPAY_CALLBACK_URL=https://my-test.kz/api/v1/billing/freedompay/callback
# Script name used in signature verification for callback URL path
FREEDOMPAY_CALLBACK_SCRIPT=callback
# Optional custom redirects
# FREEDOMPAY_SUCCESS_URL=https://my-test.kz/paywall?payment=success
# FREEDOMPAY_FAILURE_URL=https://my-test.kz/paywall?payment=failed

# Bulk import API (POST /api/v1/bulk/*) — только для временного наполнения; выключите в проде
# BULK_IMPORT_ENABLED=true
# Опционально: если задан, все запросы к /bulk/* кроме GET /bulk/status требуют заголовок X-Bulk-Import-Token
# BULK_IMPORT_SECRET=long_random_string

{
  "expo": {
    "name": "My Test",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a252b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanjuniperodee.mobile",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "My Test",
        "NSLocationWhenInUseUsageDescription": "Используем геолокацию чтобы определить тип экзамена по стране."
      }
    },
    "android": {
      "package": "com.sanjuniperodee.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a252b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      "react-native-iap",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Используем геолокацию чтобы определить тип экзамена по стране."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложение использует фото для загрузки аватарки.",
          "cameraPermission": "Приложение использует камеру для аватарки."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cdb0e735-5aa6-4490-9fd3-b491a0c7fb4e"
      }
    }
  }
}

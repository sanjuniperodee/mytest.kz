# Скопируйте в `.env` и при необходимости поправьте. Expo подхватывает только переменные с префиксом EXPO_PUBLIC_*.

# Хост API без пути /api/v1 (его добавляет lib/api/client.ts).
# Итоговые запросы: https://api.my-test.kz/api/v1/...
EXPO_PUBLIC_API_ORIGIN=https://api.my-test.kz

# Веб: только EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID (тип «Веб-приложение», OAuth consent настроен).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# iOS / Android (обязательно для сборки на телефоне): отдельные клиенты в Google Cloud.
# Иначе Google вернёт: «Custom scheme URIs are not allowed for WEB client type» — веб-клиент
# не принимает redirect вида com.your.app:/oauthredirect.
# iOS: тип «iOS», Bundle ID = ios.bundleIdentifier из app.json (напр. com.sanjuniperodee.mobile).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
# Android: тип «Android», package + SHA-1 подписи (debug/release).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# В Expo Go bundle ID другой (не как в app.json) — для Google входа обычно нужна dev/production сборка приложения.

EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=bilimhan_bot
EXPO_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/bilimilimland
EXPO_PUBLIC_WHATSAPP_NUMBER=

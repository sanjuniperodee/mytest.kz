{
  "name": "@bilimland/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate && npm -w @bilimland/shared run build",
    "build": "nest build",
    "predev": "prisma generate",
    "dev": "nest start --watch",
    "prestart": "prisma generate",
    "start": "nest start",
    "start:prod": "prisma generate && node dist/src/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "seed:math-sauat": "ts-node prisma/seed-math-sauat.ts",
    "seed:reading-sauat": "ts-node prisma/seed-reading-sauat.ts",
    "seed:history-kz-ent-kk": "ts-node prisma/seed-history-kz-ent-kk.ts",
    "seed:history-kz-ent-ru": "ts-node prisma/seed-history-kz-ent-ru.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "@bilimland/shared": "*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "multer": "^1.4.5-lts.1",
    "ioredis": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "telegraf": "^4.16.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}

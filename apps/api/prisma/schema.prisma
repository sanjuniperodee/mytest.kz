generator client {
  provider = "prisma-client-js"
  // Monorepo: path relative to this file — apps/api/prisma → ../../../ = repo root.
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ExamType {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(20)
  name        Json     // {"kk": "...", "ru": "...", "en": "..."}
  description Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  subjects      Subject[]
  questions     Question[]
  testTemplates TestTemplate[]
  testSessions  TestSession[]
  subscriptions Subscription[]
  planRules     SubscriptionPlanTemplateExamRule[]
  entitlements  UserExamEntitlement[]
  usageLedger   AttemptUsageLedger[]
  dailyUsage    UserExamDailyUsage[]

  @@map("exam_types")
}

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  examTypeId  String   @map("exam_type_id") @db.Uuid
  slug        String   @db.VarChar(50)
  name        Json     // {"kk": "...", "ru": "...", "en": "..."}
  isMandatory Boolean  @default(false) @map("is_mandatory")
  sortOrder   Int      @default(0) @map("sort_order")

  examType             ExamType               @relation(fields: [examTypeId], references: [id])
  topics               Topic[]
  questions            Question[]
  testTemplateSections TestTemplateSection[]

  @@unique([examTypeId, slug])
  @@map("subjects")
}

model Topic {
  id        String @id @default(uuid()) @db.Uuid
  subjectId String @map("subject_id") @db.Uuid
  name      Json   // {"kk": "...", "ru": "...", "en": "..."}
  sortOrder Int    @default(0) @map("sort_order")

  subject   Subject    @relation(fields: [subjectId], references: [id])
  questions Question[]

  @@map("topics")
}

model Question {
  id          String   @id @default(uuid()) @db.Uuid
  topicId     String   @map("topic_id") @db.Uuid
  subjectId   String   @map("subject_id") @db.Uuid
  examTypeId  String   @map("exam_type_id") @db.Uuid
  difficulty  Int      @db.SmallInt
  type        String   @default("single_choice") @db.VarChar(20)
  content     Json     // {"kk": {"passage?","topicLine?","text","hint?"}, ...}
  explanation Json?    // {"kk": "...", "ru": "...", "en": "..."} — premium
  imageUrls   Json?    @map("image_urls")
  metadata    Json?
  /// Балл за верный ответ (ЕНТ: обычно 1; профиль 31–40 — 2). Если null — берётся правило секции шаблона.
  scoreWeight Int?     @map("score_weight") @db.SmallInt
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  topic         Topic          @relation(fields: [topicId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id])
  examType      ExamType       @relation(fields: [examTypeId], references: [id])
  answerOptions AnswerOption[]
  testAnswers   TestAnswer[]

  @@index([subjectId, isActive])
  @@index([examTypeId, isActive])
  @@index([topicId])
  @@index([metadata], type: Gin)
  @@map("questions")
}

model AnswerOption {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  content    Json    // {"kk": "...", "ru": "...", "en": "..."}
  isCorrect  Boolean @default(false) @map("is_correct")
  sortOrder  Int     @default(0) @map("sort_order")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answer_options")
}

model TestTemplate {
  id           String  @id @default(uuid()) @db.Uuid
  examTypeId   String  @map("exam_type_id") @db.Uuid
  name         Json    // {"kk": "...", "ru": "...", "en": "..."}
  durationMins Int     @map("duration_mins")
  isActive     Boolean @default(true) @map("is_active")

  examType     ExamType              @relation(fields: [examTypeId], references: [id])
  sections     TestTemplateSection[]
  testSessions TestSession[]

  @@map("test_templates")
}

model TestTemplateSection {
  id            String @id @default(uuid()) @db.Uuid
  templateId    String @map("template_id") @db.Uuid
  subjectId     String @map("subject_id") @db.Uuid
  questionCount Int    @map("question_count")
  selectionMode String @default("random") @db.VarChar(20)
  sortOrder     Int    @default(0) @map("sort_order")
  /// Профиль ЕНТ: с какого по счёту вопроса в секции (1-based) начислять 2 балла; null — не задано (дефолт 31 в scorer)
  profileHeavyFrom Int? @map("profile_heavy_from") @db.SmallInt

  template TestTemplate @relation(fields: [templateId], references: [id])
  subject  Subject      @relation(fields: [subjectId], references: [id])

  @@map("test_template_sections")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  telegramId        BigInt    @unique @map("telegram_id")
  telegramUsername   String?   @map("telegram_username") @db.VarChar(100)
  /// E.164 digits without +, e.g. 77001234567 — set when user shares contact in bot; used for web login
  phone             String?   @unique @map("phone") @db.VarChar(20)
  firstName         String?   @map("first_name") @db.VarChar(100)
  lastName          String?   @map("last_name") @db.VarChar(100)
  preferredLanguage String    @default("ru") @map("preferred_language") @db.VarChar(2)
  isChannelMember   Boolean   @default(false) @map("is_channel_member")
  channelCheckedAt  DateTime? @map("channel_checked_at") @db.Timestamptz
  timezone          String    @default("Asia/Almaty") @db.VarChar(80)
  timezoneChangedAt DateTime? @map("timezone_changed_at") @db.Timestamptz
  entTrialUsed      Int       @default(0) @map("ent_trial_used")
  isAdmin           Boolean   @default(false) @map("is_admin")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions        Subscription[]  @relation("UserSubscriptions")
  grantedSubscriptions Subscription[]  @relation("GrantedSubscriptions")
  testSessions         TestSession[]
  paymentOrders        PaymentOrder[]
  planTemplatesCreated SubscriptionPlanTemplate[] @relation("PlanTemplateCreatedBy")
  entitlements         UserExamEntitlement[]      @relation("EntitlementsByUser")
  entitlementsGranted  UserExamEntitlement[]      @relation("EntitlementsGrantedBy")
  usageLedger          AttemptUsageLedger[]
  dailyUsage           UserExamDailyUsage[]
  visitEvents          VisitEvent[]

  @@map("users")
}

model Subscription {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  planType    String    @map("plan_type") @db.VarChar(20)
  examTypeId  String?   @map("exam_type_id") @db.Uuid
  grantedBy   String?   @map("granted_by") @db.Uuid
  startsAt    DateTime  @map("starts_at") @db.Timestamptz
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  isActive    Boolean   @default(true) @map("is_active")
  paymentNote String?   @map("payment_note") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user     User      @relation("UserSubscriptions", fields: [userId], references: [id])
  grantor  User?     @relation("GrantedSubscriptions", fields: [grantedBy], references: [id])
  examType ExamType? @relation(fields: [examTypeId], references: [id])
  entitlements UserExamEntitlement[]

  @@index([userId, isActive, expiresAt])
  @@map("subscriptions")
}

enum EntitlementTier {
  free
  trial
  paid
  admin
}

enum EntitlementStatus {
  active
  exhausted
  revoked
  expired
}

enum EntitlementSourceType {
  plan_template
  subscription
  legacy_free_trial
  legacy_trial_subscription
  legacy_paid_subscription
  admin_override
  manual
}

enum AttemptLedgerAction {
  attempt_consumed
  daily_blocked
  total_blocked
  denied_no_entitlement
  manual_adjust
  timezone_changed
  status_changed
  backfill
}

model SubscriptionPlanTemplate {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique @db.VarChar(64)
  name               String
  description        String?  @db.Text
  isActive           Boolean  @default(true) @map("is_active")
  isPremium          Boolean  @default(false) @map("is_premium")
  durationDays       Int?     @map("duration_days")
  totalAttemptsLimit Int?     @map("total_attempts_limit")
  dailyAttemptsLimit Int?     @map("daily_attempts_limit")
  timezoneMode       String   @default("user") @map("timezone_mode") @db.VarChar(16)
  metadata           Json?
  createdBy          String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  creator      User?                             @relation("PlanTemplateCreatedBy", fields: [createdBy], references: [id])
  examRules     SubscriptionPlanTemplateExamRule[]
  entitlements  UserExamEntitlement[]

  @@map("subscription_plan_templates")
}

model SubscriptionPlanTemplateExamRule {
  id                 String  @id @default(uuid()) @db.Uuid
  planTemplateId     String  @map("plan_template_id") @db.Uuid
  examTypeId         String  @map("exam_type_id") @db.Uuid
  totalAttemptsLimit Int?    @map("total_attempts_limit")
  dailyAttemptsLimit Int?    @map("daily_attempts_limit")
  isUnlimited        Boolean @default(false) @map("is_unlimited")
  sortOrder          Int     @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  planTemplate SubscriptionPlanTemplate @relation(fields: [planTemplateId], references: [id], onDelete: Cascade)
  examType     ExamType                 @relation(fields: [examTypeId], references: [id], onDelete: Cascade)

  @@unique([planTemplateId, examTypeId])
  @@index([examTypeId])
  @@map("subscription_plan_template_exam_rules")
}

model UserExamEntitlement {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @map("user_id") @db.Uuid
  examTypeId         String                @map("exam_type_id") @db.Uuid
  tier               EntitlementTier
  status             EntitlementStatus     @default(active)
  sourceType         EntitlementSourceType @map("source_type")
  sourceRef          String?               @map("source_ref") @db.VarChar(120)
  planTemplateId     String?               @map("plan_template_id") @db.Uuid
  subscriptionId     String?               @map("subscription_id") @db.Uuid
  totalAttemptsLimit Int?                  @map("total_attempts_limit")
  dailyAttemptsLimit Int?                  @map("daily_attempts_limit")
  usedAttemptsTotal  Int                   @default(0) @map("used_attempts_total")
  timezone           String                @default("Asia/Almaty") @db.VarChar(80)
  timezoneLockedUntil DateTime?            @map("timezone_locked_until") @db.Timestamptz
  windowStartsAt     DateTime              @map("window_starts_at") @db.Timestamptz
  windowEndsAt       DateTime?             @map("window_ends_at") @db.Timestamptz
  nextAllowedAt      DateTime?             @map("next_allowed_at") @db.Timestamptz
  lastAttemptAt      DateTime?             @map("last_attempt_at") @db.Timestamptz
  exhaustedAt        DateTime?             @map("exhausted_at") @db.Timestamptz
  revokedAt          DateTime?             @map("revoked_at") @db.Timestamptz
  createdBy          String?               @map("created_by") @db.Uuid
  metadata           Json?
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  user          User                      @relation("EntitlementsByUser", fields: [userId], references: [id], onDelete: Cascade)
  examType      ExamType                  @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  planTemplate  SubscriptionPlanTemplate? @relation(fields: [planTemplateId], references: [id], onDelete: SetNull)
  subscription  Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  grantor       User?                     @relation("EntitlementsGrantedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  usageLedger   AttemptUsageLedger[]
  dailyUsage    UserExamDailyUsage[]

  @@index([userId, examTypeId, status])
  @@index([windowStartsAt, windowEndsAt])
  @@index([tier, status])
  @@unique([sourceType, sourceRef])
  @@map("user_exam_entitlements")
}

model UserExamDailyUsage {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  examTypeId    String   @map("exam_type_id") @db.Uuid
  entitlementId String   @map("entitlement_id") @db.Uuid
  localDay      String   @map("local_day") @db.VarChar(10) // YYYY-MM-DD in entitlement timezone
  attemptsUsed  Int      @default(0) @map("attempts_used")
  timezone      String   @db.VarChar(80)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  examType    ExamType           @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  entitlement UserExamEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)

  @@unique([entitlementId, localDay])
  @@index([userId, examTypeId, localDay])
  @@map("user_exam_daily_usage")
}

model AttemptUsageLedger {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  examTypeId    String             @map("exam_type_id") @db.Uuid
  entitlementId String?            @map("entitlement_id") @db.Uuid
  sessionId     String?            @map("session_id") @db.Uuid
  action        AttemptLedgerAction
  reasonCode    String?            @map("reason_code") @db.VarChar(64)
  attemptsDelta Int                @default(0) @map("attempts_delta")
  localDay      String?            @map("local_day") @db.VarChar(10)
  metadata      Json?
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  examType    ExamType            @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  entitlement UserExamEntitlement? @relation(fields: [entitlementId], references: [id], onDelete: SetNull)
  session     TestSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, examTypeId, createdAt])
  @@index([entitlementId, createdAt])
  @@index([reasonCode])
  @@map("attempt_usage_ledger")
}

model TestSession {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  templateId     String?   @map("template_id") @db.Uuid
  examTypeId     String    @map("exam_type_id") @db.Uuid
  status         String    @default("in_progress") @db.VarChar(20)
  language       String    @db.VarChar(2)
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz
  durationSecs   Int?      @map("duration_secs")
  timeRemaining  Int?      @map("time_remaining")
  totalQuestions Int       @map("total_questions")
  correctCount   Int?      @map("correct_count")
  score          Decimal?  @db.Decimal(5, 2)
  rawScore       Int?      @map("raw_score")
  maxScore       Int?      @map("max_score")
  metadata       Json?     // sections info, profile subject ids
  visitId        String?   @map("visit_id") @db.Uuid

  user         User          @relation(fields: [userId], references: [id])
  template     TestTemplate? @relation(fields: [templateId], references: [id])
  examType     ExamType      @relation(fields: [examTypeId], references: [id])
  visit        VisitEvent?   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  answers      TestAnswer[]
  usageLedger  AttemptUsageLedger[]
  funnelSteps  FunnelStep[]

  @@index([userId, status])
  @@index([userId, startedAt])
  @@index([visitId])
  @@map("test_sessions")
}

model TestAnswer {
  id           String    @id @default(uuid()) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  questionId   String    @map("question_id") @db.Uuid
  selectedIds  String[]  @map("selected_ids") @db.Uuid
  isCorrect    Boolean?  @map("is_correct")
  answeredAt   DateTime? @map("answered_at") @db.Timestamptz
  timeSpentSecs Int?     @map("time_spent_secs")

  session  TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("test_answers")
}

/// Официальный код вуза (колонки матрицы грантов).
model University {
  code      Int     @id @map("code")
  name      String  @db.Text
  shortName String? @map("short_name") @db.VarChar(200)

  cutoffs GrantCutoff[]

  @@map("universities")
}

/// Образовательная программа (код Bxxx + вариант профиля при дубликатах кода).
model EntEducationalProgram {
  id                String   @id @default(uuid()) @db.Uuid
  code              String   @db.VarChar(20)
  profileVariant    Int      @default(0) @map("profile_variant")
  name              String   @db.Text
  profileSubjects   String   @map("profile_subjects") @db.Text
  profileShortLabel String?  @map("profile_short_label") @db.VarChar(100)

  cutoffs GrantCutoff[]

  @@unique([code, profileVariant])
  @@index([code])
  @@map("ent_educational_programs")
}

/// Цикл приёма (например 2023-2024).
model GrantAdmissionCycle {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(32)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  cutoffs GrantCutoff[]

  @@map("grant_admission_cycles")
}

enum GrantQuotaType {
  GRANT
  RURAL
}

/// Минимальный конкурсный балл по данным матрицы (грант / сельская квота).
model GrantCutoff {
  id              String          @id @default(uuid()) @db.Uuid
  cycleId         String          @map("cycle_id") @db.Uuid
  universityCode  Int             @map("university_code")
  programId       String          @map("program_id") @db.Uuid
  quotaType       GrantQuotaType  @map("quota_type")
  minScore        Int?            @map("min_score")

  cycle       GrantAdmissionCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  university  University              @relation(fields: [universityCode], references: [code], onDelete: Cascade)
  program     EntEducationalProgram   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([cycleId, universityCode, programId, quotaType])
  @@index([cycleId, universityCode])
  @@index([cycleId, programId])
  @@map("grant_cutoffs")
}

enum PaymentOrderStatus {
  created
  pending
  paid
  failed
  cancelled
}

model PaymentOrder {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  planCode           String             @map("plan_code") @db.VarChar(32)
  amount             Decimal            @db.Decimal(10, 2)
  currency           String             @default("KZT") @db.VarChar(8)
  provider           String             @default("freedompay") @db.VarChar(32)
  providerOrderId    String             @unique @map("provider_order_id") @db.VarChar(120)
  providerPaymentId  String?            @map("provider_payment_id") @db.VarChar(120)
  checkoutUrl        String?            @map("checkout_url") @db.Text
  status             PaymentOrderStatus @default(created)
  providerPayload    Json?              @map("provider_payload")
  paidAt             DateTime?          @map("paid_at") @db.Timestamptz
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status, createdAt])
  @@map("payment_orders")
}

model VisitEvent {
  id          String    @id @default(uuid()) @db.Uuid
  visitorId   String    @map("visitor_id") @db.VarChar(64)
  userId      String?   @map("user_id") @db.Uuid
  source      String?   @map("source") @db.VarChar(32)
  medium      String?   @map("medium") @db.VarChar(32)
  campaign    String?   @map("campaign") @db.VarChar(64)
  referrer    String?   @map("referrer") @db.VarChar(500)
  landingPath String    @map("landing_path") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  funnelSteps  FunnelStep[]
  testSessions TestSession[]

  @@index([visitorId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("visit_events")
}

model FunnelStep {
  id        String       @id @default(uuid()) @db.Uuid
  visitId   String       @map("visit_id") @db.Uuid
  step      String       @db.VarChar(32)
  timestamp DateTime     @default(now()) @map("timestamp") @db.Timestamptz
  metadata  Json?
  sessionId String?      @map("session_id") @db.Uuid

  visit   VisitEvent   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  session TestSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([visitId])
  @@index([step, timestamp])
  @@map("funnel_steps")
}

model SiteSetting {
  key       String   @id @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("site_settings")
}
